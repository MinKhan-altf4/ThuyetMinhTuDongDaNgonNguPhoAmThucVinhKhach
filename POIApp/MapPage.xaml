<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="POIApp.MapPage"
             Title="Thuyết Minh Map">

    <Grid RowSpacing="0" ColumnSpacing="0">
        <Grid.RowDefinitions>
            <!-- Row 0: Search bar -->
            <RowDefinition Height="Auto" />
            <!-- Row 1: Map area (contains map + overlay panels) -->
            <RowDefinition Height="*" />
            <!-- Row 2: Bottom POI chips bar -->
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ── SEARCH BAR (Row 0) ── -->
        <Frame Grid.Row="0"
               Margin="10,8,10,4"
               Padding="10,0"
               HeightRequest="44"
               BackgroundColor="White"
               CornerRadius="22"
               HasShadow="True"
               ZIndex="10">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <Label Grid.Column="0"
                       Text="🔍"
                       FontSize="16"
                       VerticalOptions="Center"
                       Margin="2,0,8,0" />
                <Entry x:Name="SearchEntry"
                       Grid.Column="1"
                       Placeholder="Tìm nhà hàng Vĩnh Khánh..."
                       FontSize="14"
                       VerticalOptions="Center"
                       Completed="OnSearchCompleted"
                       TextChanged="OnSearchTextChanged"
                       BackgroundColor="Transparent" />
                <Button x:Name="BtnClearSearch"
                        Grid.Column="2"
                        Text="✕"
                        FontSize="13"
                        WidthRequest="32"
                        HeightRequest="32"
                        CornerRadius="16"
                        Padding="0"
                        BackgroundColor="Transparent"
                        TextColor="#9E9E9E"
                        Clicked="OnClearSearchClicked"
                        IsVisible="False" />
            </Grid>
        </Frame>

        <!-- ── MAP AREA (Row 1) — ZIndex overlay hoạt động đúng vì overlay nằm TRONG local Grid ── -->
        <Grid Grid.Row="1" ZIndex="1">

            <!-- Map fills entire area -->
            <WebView x:Name="MapWebView"
                     ZIndex="1" />

            <!-- Status bar (floats on map) -->
            <Frame VerticalOptions="Start"
                   HorizontalOptions="Fill"
                   Margin="12,12,12,0"
                   Padding="10,8"
                   BackgroundColor="#E3F2FD"
                   CornerRadius="12"
                   HasShadow="False"
                   ZIndex="5">
                <VerticalStackLayout Spacing="2">
                    <Label x:Name="LblUserStatus"
                           Text="Đang lấy vị trí..."
                           FontSize="12"
                           TextColor="#0D47A1" />
                    <Label x:Name="LblNearestStatus"
                           Text=""
                           FontSize="11"
                           TextColor="#455A64" />
                </VerticalStackLayout>
            </Frame>

            <!-- Search suggestions popup (floats on map) -->
            <Frame x:Name="SearchSuggestionsPanel"
                   VerticalOptions="Start"
                   HorizontalOptions="Fill"
                   Margin="12,66,12,0"
                   Padding="0"
                   BackgroundColor="White"
                   CornerRadius="12"
                   HasShadow="True"
                   IsVisible="False"
                   ZIndex="10">
                <ScrollView HeightRequest="260">
                    <VerticalStackLayout x:Name="SearchSuggestionsContainer" Spacing="0" />
                </ScrollView>
            </Frame>

            <!-- Floating controls (bottom-left, vertical stack: ZoomIn → ZoomOut → Refresh) -->
            <VerticalStackLayout VerticalOptions="End"
                                 HorizontalOptions="Start"
                                 Margin="12,0,0,12"
                                 Spacing="6"
                                 ZIndex="10">
                <Button x:Name="BtnZoomIn"
                        Text="+"
                        FontSize="20"
                        FontAttributes="Bold"
                        WidthRequest="48"
                        HeightRequest="48"
                        CornerRadius="24"
                        Padding="0"
                        BackgroundColor="White"
                        TextColor="#1565C0"
                        Clicked="OnZoomInClicked" />
                <Button x:Name="BtnZoomOut"
                        Text="−"
                        FontSize="20"
                        FontAttributes="Bold"
                        WidthRequest="48"
                        HeightRequest="48"
                        CornerRadius="24"
                        Padding="0"
                        BackgroundColor="White"
                        TextColor="#1565C0"
                        Clicked="OnZoomOutClicked" />
                <Button x:Name="BtnReloadPOI"
                        Text="🔄"
                        FontSize="18"
                        WidthRequest="48"
                        HeightRequest="48"
                        CornerRadius="24"
                        Padding="0"
                        BackgroundColor="White"
                        TextColor="#1565C0"
                        Clicked="OnReloadPOIClicked" />
            </VerticalStackLayout>

            <!-- POI Detail Panel (floats on map, highest z-index) -->
            <Frame x:Name="POIDetailPanel"
                   VerticalOptions="End"
                   Margin="12,0,12,12"
                   Padding="14"
                   BackgroundColor="White"
                   CornerRadius="18"
                   HasShadow="True"
                   IsVisible="False"
                   ZIndex="15">
                <VerticalStackLayout Spacing="10">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <Label x:Name="LblPOIName"
                               Text=""
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="#0D47A1"
                               VerticalOptions="Center" />
                        <Button Grid.Column="1"
                                Text="✕"
                                FontSize="13"
                                WidthRequest="30"
                                HeightRequest="30"
                                CornerRadius="15"
                                Padding="0"
                                BackgroundColor="#FFEBEE"
                                TextColor="#C62828"
                                Clicked="OnCloseDetailClicked" />
                    </Grid>

                    <Label x:Name="LblPOIDescription"
                           Text=""
                           FontSize="13"
                           TextColor="#37474F"
                           MaxLines="4"
                           LineBreakMode="TailTruncation" />

                    <HorizontalStackLayout Spacing="10">
                        <Label x:Name="LblPOIDistance"
                               Text=""
                               FontSize="12"
                               TextColor="#546E7A"
                               FontAttributes="Bold" />
                        <Label x:Name="LblPOICoords"
                               Text=""
                               FontSize="11"
                               TextColor="#78909C" />
                    </HorizontalStackLayout>

                    <VerticalStackLayout Spacing="4">
                        <Label Text="Ngôn ngữ thuyết minh"
                               FontSize="12"
                               TextColor="#607D8B" />
                        <Picker x:Name="LanguagePicker"
                                Title="Chọn ngôn ngữ"
                                FontSize="13"
                                SelectedIndexChanged="OnLanguageChanged" />
                    </VerticalStackLayout>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                        <Button x:Name="BtnPlayAudio"
                                Text="▶ Phát"                                FontSize="13"
                                HeightRequest="42"
                                CornerRadius="21"
                                BackgroundColor="#FF9800"
                                TextColor="White"
                                Clicked="OnPlayAudioClicked" />
                        <Button Grid.Column="1"
                                x:Name="BtnPauseAudio"
                                Text="⏸ Tạm dừng"
                                FontSize="13"
                                HeightRequest="42"
                                CornerRadius="21"
                                BackgroundColor="#455A64"
                                TextColor="White"
                                Clicked="OnPauseAudioClicked" />
                    </Grid>

                    <Label x:Name="LblAudioStatus"
                           Text=""
                           FontSize="11"
                           TextColor="#00897B" />

                    <ActivityIndicator x:Name="AudioLoading"
                                       IsRunning="False"
                                       IsVisible="False"
                                       Color="#FF9800"
                                       HorizontalOptions="Center" />

                    <Button Text="📍 Chỉ đường đến đây"
                            FontSize="13"
                            HeightRequest="42"
                            CornerRadius="21"
                            BackgroundColor="#43A047"
                            TextColor="White"
                            Clicked="OnNavigateClicked" />
                </VerticalStackLayout>
            </Frame>
        </Grid>

        <!-- ── BOTTOM: POI CHIPS (Row 2) — layout đơn giản không bo tròn ── -->
        <Grid Grid.Row="2"
              BackgroundColor="White"
              Padding="12,10"
              ZIndex="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Label Grid.Row="0"
                   Text="Địa điểm gần bạn"
                   FontSize="14"
                   FontAttributes="Bold"
                   TextColor="#263238"
                   Margin="0,0,0,6" />
            <ScrollView Grid.Row="1"
                        Orientation="Horizontal"
                        HorizontalScrollBarVisibility="Never">
                <HorizontalStackLayout x:Name="POIChipsContainer" Spacing="8" />
            </ScrollView>
        </Grid>
    </Grid>
</ContentPage>
