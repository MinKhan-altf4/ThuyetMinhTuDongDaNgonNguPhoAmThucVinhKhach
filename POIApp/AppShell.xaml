<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="POIApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:POIApp"
    Title="Thuyết Minh Ẩm Thực"
    Shell.TabBarBackgroundColor="#FAFAFA"
    Shell.TabBarTitleColor="#1565C0"
    Shell.TabBarUnselectedColor="#9E9E9E">

    <Tab x:Name="TabMap" Route="MapTab">
        <ShellContent>
            <local:MapPage />
        </ShellContent>
    </Tab>

    <Tab x:Name="TabPOI" Route="POITab">
        <ShellContent>
            <local:POIPage />
        </ShellContent>
    </Tab>

    <Tab x:Name="TabSettings" Route="SettingsTab">
        <ShellContent>
            <local:SettingsPage />
        </ShellContent>
    </Tab>

</Shell>
